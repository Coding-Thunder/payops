# =========================================================================
# TraceTxn — environment template
#
# Copy to `.env.local` for development, or paste the values that apply
# into your deployment platform's env-var UI (Vercel, DigitalOcean, etc.).
#
# Required vars (zod refuses to start without these):
#   MONGODB_URI · JWT_SECRET · STRIPE_SECRET_KEY · STRIPE_WEBHOOK_SECRET
#
# Strongly recommended for prod:
#   TRACETXN_MASTER_KEY · NEXT_PUBLIC_APP_URL · COOKIE_SECURE="true"
#
# Optional — set only if you need the feature.
# =========================================================================

# ---------- Application ----------
APP_NAME="TraceTxn"
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="TraceTxn"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# NODE_ENV is set by your runtime (Vercel sets "production" automatically).

# ---------- MongoDB ----------
# Local: mongodb://127.0.0.1:27017/tracetxn
# Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority
MONGODB_URI=""
MONGODB_DB="tracetxn"

# ---------- Auth ----------
# Generate per env: openssl rand -base64 64    (must be ≥ 32 chars)
JWT_SECRET=""
COOKIE_NAME="tracetxn_session"
# Required "true" over HTTPS; set "false" only for plain-HTTP local dev.
COOKIE_SECURE="true"
# Optional: cross-subdomain scope, e.g. ".yourdomain.com"
# COOKIE_DOMAIN=""

# ---------- Gateway-credentials encryption ----------
# AES-256 master key. Required the moment ANY org connects Stripe via
# /admin/gateways. Generate fresh per env: openssl rand -base64 32
# Loss of this key locks all encrypted gateway credentials.
TRACETXN_MASTER_KEY=""

# ---------- Stripe ----------
# TEST keys: https://dashboard.stripe.com/test/apikeys
# LIVE keys: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Endpoint URL pattern: <APP_URL>/api/webhooks/stripe/<orgId>
# Each tenant gets a unique webhook URL after they connect their Stripe.
STRIPE_WEBHOOK_SECRET=""

# ---------- SMTP (Resend is the default outbound relay) ----------
# Outbound mail runs through Resend's SMTP. Zoho continues to own
# inbound + human reply-from-mailbox on root tracetxn.com; the two
# providers run side by side (Resend lives under send.tracetxn.com,
# never touches root MX).
#
# How to get SMTP_PASS:
#   1. Resend dashboard → API Keys → Create
#   2. Permission = Sending access · Domain = tracetxn.com
#   3. Copy the re_… value once and paste below
#
# Leave SMTP_HOST empty to disable email entirely (sends become
# EMAIL_FAILED audit rows; order flow keeps working).
SMTP_HOST="smtp.resend.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="resend"
SMTP_PASS=""

# Tenant-side catch-all sender (marketing quotation ack + tenant
# commerce mail when Branding.senderEmail is empty). Must sit on the
# verified Resend domain.
EMAIL_FROM="TraceTxn <hello@tracetxn.com>"

# Platform-side account-lifecycle sender (password reset, signup
# welcome, trial events, subscription events, security alerts).
EMAIL_FROM_ACCOUNTS="TraceTxn Accounts <accounts@tracetxn.com>"

# Replies to platform emails route here. Leave blank to default replies
# back to whichever From address sent the mail.
EMAIL_REPLY_TO="support@tracetxn.com"

# ---------- Cloudflare Turnstile (optional) ----------
# Bot-check on /login + /api/quotations. Leave blank to disable.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
# TURNSTILE_SECRET_KEY=""

# ---------- Seed defaults (optional — overridden per-org in /admin/settings) ----------
# DEFAULT_CURRENCY="USD"
# DEFAULT_PAYMENT_EXPIRY_HOURS="24"
# DEFAULT_ORDER_PREFIX="ORD"

# ---------- Legacy single-tenant branding (optional) ----------
# Only read when seeding the legacy Branding row. Self-serve tenants
# override these in /admin/branding. Safe to omit on a fresh deploy.
# CUSTOMER_BRAND_NAME="TraceTxn"
# SUPPORT_EMAIL="support@tracetxn.example.com"
# SUPPORT_PHONE="+1-555-0100"

# ---------- Session token lifetime (optional) ----------
# Format: <num><s|m|h|d>. Hard ceiling of 7d enforced regardless.
# JWT_EXPIRES_IN="12h"

# Optional dedicated secret for consent-flow tokens (defaults to
# JWT_SECRET when unset). Rotate to a separate value so a session-token
# leak can't forge consent tokens.
# CONSENT_TOKEN_SECRET=""
